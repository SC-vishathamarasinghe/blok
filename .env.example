# Blok Documentation Site — environment variables
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Registry & site
# -----------------------------------------------------------------------------
# Base URL for the Blok registry (used in sitemap, metadata, installation commands).
# Example: https://blok.sitecore.com
NEXT_PUBLIC_REGISTRY_URL=

# -----------------------------------------------------------------------------
# Telemetry (Gainsight PX)
# -----------------------------------------------------------------------------
# Gainsight PX product key (tag). When set, the docs site loads the Gainsight script
# and sends telemetry events (e.g. page views, navigation, search result clicks).
# Leave empty to disable telemetry.
# Example: AP-XXXXXXXX-X
NEXT_PUBLIC_GAINSIGHT_PX_TAG=
